// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(cuid())
  username      String     @unique
  email         String     @unique
  password      String?    // hashed — null للمستخدمين العاديين (OAuth لاحقاً)
  avatarUrl     String?
  bannerUrl     String?    // صورة الخلفية بمقاس اليوتيوب (2560×1440)
  bio           String?
  role          String     @default("member") // member | moderator | admin | owner
  joinedAt      DateTime   @default(now())
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  mods          Mod[]      @relation("AuthoredMods")
  endorsements  Endorsement[]
  comments      ModComment[]
}

model Game {
  id            String     @id @default(cuid())
  slug          String     @unique
  name          String
  tagline       String
  description   String
  bannerUrl     String
  logoUrl       String?
  thumbnailUrl  String
  category      String     // RPG | FPS | Strategy | Sandbox | Adventure | Simulation
  platform      String     // PC | NS | PS1 | PS2 | PS3 | PS4
  releaseYear   Int
  modCount      Int        @default(0)
  totalDownloads Int       @default(0)
  totalEndorsements Int    @default(0)
  featured      Boolean    @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  mods          Mod[]
  categories    Category[]
}

model Category {
  id            String     @id @default(cuid())
  name          String
  slug          String
  game          Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)
  gameId        String
  mods          Mod[]
  createdAt     DateTime   @default(now())

  @@unique([gameId, slug])
}

model Mod {
  id              String     @id @default(cuid())
  slug            String     @unique
  name            String
  summary         String
  description     String
  changelog       String     @default("")  // سجل التغييرات (markdown)
  installGuide    String     @default("")  // دليل التركيب (markdown)
  arabicTitle     String     @default("")  // الاسم بالعربي
  compatibility   String     @default("")  // التوافق
  authorId        String
  author          User       @relation("AuthoredMods", fields: [authorId], references: [id])
  gameId          String
  game            Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)
  categoryId      String?
  category        Category?  @relation(fields: [categoryId], references: [id])
  thumbnailUrl    String
  imageUrl        String
  galleryUrls     String     // comma-separated
  version         String
  fileSize        String
  fileFormat      String     // 7z | zip | rar
  downloads       Int        @default(0)
  endorsements    Int        @default(0)
  views           Int        @default(0)
  comments        Int        @default(0)
  rating          Float      @default(0)
  ratingCount     Int        @default(0)
  tags            String     // comma-separated
  series          String     @default("") // اسم السلسلة (مثل God of War)
  translationTeam String     @default("") // فريق التعريب أو المترجم المستقل
  isFeatured      Boolean    @default(false)
  isTrending      Boolean    @default(false)
  isLatest        Boolean    @default(true)
  translationType String     @default("unofficial") // official | unofficial
  releaseDate     DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  createdAt       DateTime   @default(now())
  endorsementRecords Endorsement[]
  files           ModFile[]
  videoGroups     ModVideoGroup[]
  teamMembers     ModTeamMember[]
  contactLinks    ModContactLink[]
  customTabs      ModCustomTab[]
  commentsRecords ModComment[]
}

model Endorsement {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  modId     String
  mod       Mod      @relation(fields: [modId], references: [id], onDelete: Cascade)
  value     String   @default("up") // up | down
  createdAt DateTime @default(now())

  @@unique([userId, modId])
}

// ===== ملفات التحميل المتعددة لكل تعريب =====
model ModFile {
  id           String        @id @default(cuid())
  modId        String
  mod          Mod           @relation(fields: [modId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  alert        String?
  version      String
  releaseDate  DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  fileSize     String
  fileFormat   String
  order        Int           @default(0)
  links        ModFileLink[]
  createdAt    DateTime      @default(now())
}

// ===== روابط كل ملف تحميل =====
model ModFileLink {
  id        String   @id @default(cuid())
  fileId    String
  file      ModFile  @relation(fields: [fileId], references: [id], onDelete: Cascade)
  url       String
  label     String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

// ===== أقسام الفيديوهات (شرح/ترويجي/مراجعة) =====
model ModVideoGroup {
  id        String     @id @default(cuid())
  modId     String
  mod       Mod        @relation(fields: [modId], references: [id], onDelete: Cascade)
  name      String
  order     Int        @default(0)
  videos    ModVideo[]
  createdAt DateTime   @default(now())
}

// ===== الفيديوهات =====
model ModVideo {
  id         String        @id @default(cuid())
  groupId    String
  group      ModVideoGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  title      String
  url        String
  thumbnail  String?
  duration   String?
  views      Int           @default(0)
  channel    String?
  order      Int           @default(0)
  createdAt  DateTime      @default(now())
}

// ===== أعضاء فريق التعريب =====
model ModTeamMember {
  id            String   @id @default(cuid())
  modId         String
  mod           Mod      @relation(fields: [modId], references: [id], onDelete: Cascade)
  name          String
  avatarUrl     String?
  role          String   @default("مترجم")
  contribution  String?
  order         Int      @default(0)
  createdAt     DateTime @default(now())
}

// ===== روابط تواصل الفريق =====
model ModContactLink {
  id        String   @id @default(cuid())
  modId     String
  mod       Mod      @relation(fields: [modId], references: [id], onDelete: Cascade)
  type      String   // mail | website | telegram | twitter | youtube | discord
  label     String
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

// ===== التبويبات المخصصة =====
model ModCustomTab {
  id        String   @id @default(cuid())
  modId     String
  mod       Mod      @relation(fields: [modId], references: [id], onDelete: Cascade)
  name      String
  slug      String
  content   String   // markdown
  order     Int      @default(0)
  visible   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([modId, slug])
}

// ===== التعليقات =====
model ModComment {
  id          String       @id @default(cuid())
  modId       String
  mod         Mod          @relation(fields: [modId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  guestName   String       @default("زائر")
  guestAvatar String?
  parentId    String?
  parent      ModComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     ModComment[] @relation("CommentReplies")
  text        String
  likes       Int          @default(0)
  dislikes    Int          @default(0)
  isPinned    Boolean      @default(false)
  isEdited    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

// ===== سجل النشاطات (Audit Log) =====
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  username  String   @default("system")
  action    String   // create | update | delete | login | logout | moderate
  entity    String   // mod | game | user | comment | ad | series | setting
  entityId  String?
  details   String?  // JSON string with extra info
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([action])
  @@index([entity])
  @@index([userId])
  @@index([createdAt])
}

// ===== إعدادات الموقع =====
model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  group     String   @default("general") // general | appearance | seo | social
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// ===== إعلانات الصفحة الرئيسية =====
// بيدعم: فيديوهات يوتيوب، صور إعلانية، HTML مخصص
// بيتعرض فوق الشريط الجانبي في الصفحة الرئيسية
model HomepageAd {
  id          String   @id @default(cuid())
  type        String   @default("youtube") // youtube | image | html
  url         String   // رابط الفيديو (لـ youtube) أو رابط الصورة (لـ image) أو كود HTML (لـ html)
  title       String   @default("")
  description String   @default("")
  link        String?  // رابط عند الضغط على الإعلان (لـ image)
  size        String   @default("medium") // small | medium | large | full
  order       Int      @default(0)
  visible     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
