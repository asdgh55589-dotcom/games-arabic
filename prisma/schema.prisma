// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(cuid())
  username      String     @unique
  email         String     @unique
  avatarUrl     String?
  bio           String?
  youtubeUrl    String?
  twitterUrl    String?
  discordUrl    String?
  role          String     @default("member") // member | moderator | admin
  joinedAt      DateTime   @default(now())
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  mods          Mod[]      @relation("AuthoredMods")
  endorsements  Endorsement[]
}

model Game {
  id            String     @id @default(cuid())
  slug          String     @unique
  name          String
  tagline       String
  description   String
  bannerUrl     String
  logoUrl       String?
  thumbnailUrl  String
  category      String     // RPG | FPS | Strategy | Sandbox | Adventure | Simulation
  platform      String     // PC | PS1 | PS2 | PS3 | PS4
  releaseYear   Int
  modCount      Int        @default(0)
  totalDownloads Int       @default(0)
  totalEndorsements Int    @default(0)
  featured      Boolean    @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  mods          Mod[]
  categories    Category[]
}

model Category {
  id            String     @id @default(cuid())
  name          String
  slug          String
  game          Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)
  gameId        String
  mods          Mod[]
  createdAt     DateTime   @default(now())

  @@unique([gameId, slug])
}

model Mod {
  id              String     @id @default(cuid())
  slug            String     @unique
  name            String
  summary         String
  description     String
  authorId        String
  author          User       @relation("AuthoredMods", fields: [authorId], references: [id])
  gameId          String
  game            Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)
  categoryId      String?
  category        Category?  @relation(fields: [categoryId], references: [id])
  thumbnailUrl    String
  imageUrl        String
  galleryUrls     String     // comma-separated
  version         String
  fileSize        String
  fileFormat      String     // 7z | zip | rar
  downloads       Int        @default(0)
  endorsements    Int        @default(0)
  views           Int        @default(0)
  comments        Int        @default(0)
  rating          Float      @default(0)
  ratingCount     Int        @default(0)
  tags            String     // comma-separated
  series          String     @default("") // اسم السلسلة (مثل God of War)
  compatibility   String     @default("") // التوافق (مثل: يعمل مع النسخة 1.6+)
  translationTeam String     @default("") // فريق التعريب
  isFeatured      Boolean    @default(false)
  isTrending      Boolean    @default(false)
  isLatest        Boolean    @default(true)
  translationType String     @default("unofficial") // official | unofficial
  releaseDate     DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  createdAt       DateTime   @default(now())
  endorsementRecords Endorsement[]
}

model Endorsement {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  modId     String
  mod       Mod      @relation(fields: [modId], references: [id], onDelete: Cascade)
  value     String   @default("up") // up | down
  createdAt DateTime @default(now())

  @@unique([userId, modId])
}
